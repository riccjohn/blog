---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
    src: ImageMetadata
    alt: string
    caption: string
    class?: string
}

const {
    src,
    alt,
    caption,
    class: className = 'mx-auto block rounded-lg shadow-lg',
} = Astro.props
---

<figure>
    <Image {src} {alt} class={className} />
    <figcaption>{caption}</figcaption>
</figure>
